# Example environment variables for the backend
# Copy this file to .env and fill in the values before starting the server

# MongoDB connection string (replace with your connection string)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/authsphere?retryWrites=true&w=majority

# JWT secret used to sign and verify tokens. Use a long, random string in production.
JWT_SECRET=change_this_to_a_strong_secret

# Optional: port the server will listen on (defaults to 5000)
PORT=5000
